<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:NewsApp.Views"
       x:Class="NewsApp.AppShell">
    <ShellContent Title="News" ContentTemplate="{DataTemplate views:NewsListPage}" Route="NewsListPage"/>
    <ShellContent Title="Categories" ContentTemplate="{DataTemplate views:CategorySelectionPage}" Route="CategorySelectionPage"/>
    <ShellContent Title="Article" ContentTemplate="{DataTemplate views:ArticleDetailPage}" Route="ArticleDetailPage"/>
</Shell>