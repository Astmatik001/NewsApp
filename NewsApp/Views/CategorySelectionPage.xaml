<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApp.Views.CategorySelectionPage"
             Title="Выберите интересы">
    <VerticalStackLayout Spacing="20" Padding="20">
        <Label Text="Какие темы вам интересны?" FontSize="24" HorizontalOptions="Center"/>
        <CollectionView ItemsSource="{Binding AvailableCategories}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Button Text="{Binding NameRu}" 
                            Command="{Binding BindingContext.ToggleCategoryCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                            CommandParameter="{Binding .}"
                            BackgroundColor="LightGray"
                            Margin="5"/>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Button Text="Продолжить" 
                Command="{Binding SaveAndContinueCommand}" 
                HorizontalOptions="Center"/>
    </VerticalStackLayout>
</ContentPage>