<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApp.Views.NewsListPage"
             Title="Новости">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackLayout Grid.Row="0" BackgroundColor="White">
            <Frame BackgroundColor="#E3F2FD" CornerRadius="0" Padding="15" HasShadow="False">
                <StackLayout>
                    <StackLayout Orientation="Horizontal">
                        <Label Text="🗞️ " FontSize="20"/>
                        <Label Text="Ваши новости" FontSize="18" FontAttributes="Bold" TextColor="#1A1A2E"/>
                    </StackLayout>
                    <StackLayout Orientation="Horizontal" Margin="0,8,0,0">
                        <Label Text="Интересы: " FontSize="12" TextColor="#888"/>
                        <Label x:Name="CategoriesLabel" FontSize="12" TextColor="#1976D2"/>
                    </StackLayout>
                </StackLayout>
            </Frame>
            
            <!-- Action Buttons -->
            <StackLayout Orientation="Horizontal" Padding="10" Spacing="10">
                <Button Text="🏠 Главная" FontSize="11" Padding="10,8" BackgroundColor="#E8F5E9" TextColor="#2E7D32" CornerRadius="15"/>
                <Button Text="🔖 Закладки" Clicked="OnBookmarksClicked" FontSize="11" Padding="10,8" BackgroundColor="#FFF3E0" TextColor="#E65100" CornerRadius="15"/>
                <Button Text="📜 Подписка" Clicked="OnPremiumClicked" FontSize="11" Padding="10,8" BackgroundColor="#F3E5F5" TextColor="#9C27B0" CornerRadius="15"/>
                <Button Text="⚙️ Настройки" Clicked="OnChangeCategories" FontSize="11" Padding="10,8" BackgroundColor="#E3F2FD" TextColor="#1565C0" CornerRadius="15"/>
            </StackLayout>
        </StackLayout>
        
        <!-- Loading Indicator -->
        <StackLayout Grid.Row="1" 
                     IsVisible="{Binding IsRefreshing}"
                     VerticalOptions="Center"
                     HorizontalOptions="Center"
                     Spacing="10">
            <ActivityIndicator IsRunning="{Binding IsRefreshing}" 
                               Color="#1976D2"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>
            <Label Text="Загрузка новостей..."
                   FontSize="14" TextColor="#666" HorizontalOptions="Center"/>
        </StackLayout>
        
        <!-- News List -->
        <ListView Grid.Row="1" 
                  ItemsSource="{Binding Headlines}" 
                  ItemSelected="OnItemSelected" 
                  HasUnevenRows="True" 
                  BackgroundColor="#F5F5F5"
                  Margin="0"
                  IsVisible="{Binding IsListVisible}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Frame BackgroundColor="White" Margin="10,5" CornerRadius="15" Padding="15">
                            <StackLayout>
                                <!-- Category Badge -->
                                <Frame BackgroundColor="#E3F2FD" CornerRadius="10" Padding="8,4" HorizontalOptions="Start" Margin="0,0,0,8">
                                    <Label Text="{Binding Category}" FontSize="10" TextColor="#1976D2" FontAttributes="Bold"/>
                                </Frame>
                                
                                <!-- Title -->
                                <Label Text="{Binding Title}" 
                                       FontSize="15" FontAttributes="Bold" 
                                       TextColor="#1A1A2E" 
                                       MaxLines="3" LineBreakMode="WordWrap"/>
                                
                                <!-- Summary -->
                                <Label Text="{Binding Summary}" 
                                       FontSize="12" TextColor="#666" 
                                       MaxLines="2" Margin="0,8,0,0"/>
                                
                                <!-- Source & Date -->
                                <StackLayout Orientation="Horizontal" Margin="0,10,0,0">
                                    <Label Text="📰 " FontSize="10"/>
                                    <Label Text="{Binding Source}" FontSize="10" TextColor="#888"/>
                                </StackLayout>
                            </StackLayout>
                        </Frame>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
        <!-- Empty State -->
        <StackLayout Grid.Row="1" 
                     IsVisible="{Binding IsEmptyVisible}"
                     VerticalOptions="Center"
                     HorizontalOptions="Center"
                     Spacing="15">
            <Label Text="📭" FontSize="48" HorizontalOptions="Center"/>
            <Label Text="{Binding ErrorMessage}"
                   FontSize="14" TextColor="#888" HorizontalOptions="Center"/>
            
            <!-- Limit Message with Upgrade Button -->
            <StackLayout IsVisible="{Binding ShowLimitMessage}"
                         Spacing="10" HorizontalOptions="Center">
                <Label Text="Это лимит бесплатного тарифа."
                       FontSize="14" TextColor="#666" HorizontalOptions="Center"/>
                <Button Text="Изменить подписку"
                        BackgroundColor="#FF9800"
                        TextColor="White"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="20"
                        HeightRequest="40"
                        WidthRequest="180"
                        Clicked="OnChangeSubscription"/>
            </StackLayout>
        </StackLayout>
    </Grid>
</ContentPage>