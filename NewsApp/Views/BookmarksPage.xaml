<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApp.Views.BookmarksPage"
             Title="🔖 Закладки"
             BackgroundColor="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Frame Grid.Row="0" BackgroundColor="White" CornerRadius="0" Padding="15" HasShadow="True">
            <StackLayout>
                <Label Text="🔖 Ваши закладки" FontSize="20" FontAttributes="Bold" TextColor="#1A1A2E"/>
                <Label Text="Сохраняйте понравившиеся статьи" FontSize="12" TextColor="#888" Margin="0,5,0,0"/>
            </StackLayout>
        </Frame>
        
        <!-- Tab Buttons -->
        <StackLayout Grid.Row="1" Orientation="Horizontal" HorizontalOptions="Center" Padding="15" Spacing="15" BackgroundColor="#F5F5F5">
            <Button x:Name="ReadTabButton" Text="✓ Прочитано" Clicked="OnReadTab" WidthRequest="130" HeightRequest="40" BackgroundColor="#4CAF50" TextColor="White" CornerRadius="20"/>
            <Button x:Name="FavoriteTabButton" Text="★ Избранное" Clicked="OnFavoriteTab" WidthRequest="130" HeightRequest="40" BackgroundColor="#E0E0E0" TextColor="#666" CornerRadius="20"/>
        </StackLayout>
        
        <!-- List -->
        <CollectionView Grid.Row="1" x:Name="ItemsListView" SelectionMode="Single" SelectionChanged="OnItemSelected" BackgroundColor="#F5F5F5" Margin="0,80,0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="White" Margin="10,5" CornerRadius="15" Padding="15" HasShadow="True">
                        <StackLayout>
                            <Label Text="{Binding Title}" FontSize="15" FontAttributes="Bold" TextColor="#1A1A2E" MaxLines="2"/>
                            <Label Text="{Binding Summary}" FontSize="12" TextColor="#666" MaxLines="2" Margin="0,5,0,0"/>
                            <StackLayout Orientation="Horizontal" Margin="0,8,0,0">
                                <Label Text="📰 " FontSize="10"/>
                                <Label Text="{Binding Source}" FontSize="10" TextColor="#888"/>
                            </StackLayout>
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>