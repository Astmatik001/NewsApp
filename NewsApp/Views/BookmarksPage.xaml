<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApp.Views.BookmarksPage"
             Title="Закладки">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackLayout Grid.Row="0" Padding="10" Spacing="10">
            <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="10">
                <Button x:Name="ReadTabButton" Text="Прочитано" Clicked="OnReadTab" WidthRequest="140" HeightRequest="40"/>
                <Button x:Name="FavoriteTabButton" Text="Избранное" Clicked="OnFavoriteTab" WidthRequest="140" HeightRequest="40"/>
            </StackLayout>
        </StackLayout>
        
        <ListView Grid.Row="1" x:Name="ItemsListView" ItemSelected="OnItemSelected" HasUnevenRows="True" BackgroundColor="#F5F5F5">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <StackLayout Padding="15,12" BackgroundColor="White">
                            <Label Text="{Binding Title}" FontSize="15" FontAttributes="Bold" TextColor="Black"/>
                            <Label Text="{Binding Summary}" FontSize="12" TextColor="Gray" MaxLines="2" Margin="0,5,0,0"/>
                            <Label Text="{Binding Source}" FontSize="10" TextColor="#888" Margin="0,5,0,0"/>
                        </StackLayout>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</ContentPage>