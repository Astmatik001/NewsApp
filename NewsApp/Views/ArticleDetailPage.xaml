<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApp.Views.ArticleDetailPage"
             Title="📖 Статья"
             BackgroundColor="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header (unchanged) -->
        <Frame Grid.Row="0" BackgroundColor="White" CornerRadius="0" Padding="15" HasShadow="True">
            <StackLayout>
                <Label x:Name="TitleLabel" FontSize="22" FontAttributes="Bold" TextColor="#1A1A2E" LineBreakMode="WordWrap"/>
                <StackLayout Orientation="Horizontal" Margin="0,10,0,0">
                    <Label Text="📰 " FontSize="12"/>
                    <Label x:Name="SourceLabel" FontSize="12" TextColor="#1976D2"/>
                </StackLayout>
            </StackLayout>
        </Frame>

        <!-- Action Buttons (unchanged) -->
        <Frame Grid.Row="1" BackgroundColor="White" CornerRadius="0" Padding="10" HasShadow="False">
            <StackLayout Orientation="Horizontal" Spacing="15" HorizontalOptions="Center">
                <HorizontalStackLayout Spacing="5">
                    <CheckBox x:Name="ReadCheckBox" Color="#4CAF50" VerticalOptions="Center"/>
                    <Label x:Name="ReadLabel" Text="Прочитано" FontSize="12" TextColor="#666" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnReadTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="5">
                    <CheckBox x:Name="FavoriteCheckBox" Color="#FF9800" VerticalOptions="Center"/>
                    <Label x:Name="FavoriteLabel" Text="Избранное" FontSize="12" TextColor="#666" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFavoriteTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </StackLayout>
        </Frame>

        <!-- Content – WebView instead of Label -->
        <ScrollView Grid.Row="2" Padding="15">
            <Frame BackgroundColor="White" CornerRadius="15" Padding="0" HasShadow="True">
                <WebView x:Name="ContentWebView" 
                         Navigating="OnWebViewNavigating"
                         Navigated="OnWebViewNavigated"
                         BackgroundColor="White"/>
            </Frame>
        </ScrollView>

        <!-- Translation button (new) -->
        <Frame Grid.Row="3" BackgroundColor="White" CornerRadius="0" Padding="15,10" HasShadow="False">
            <StackLayout Spacing="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="TtsButton"
                            Text="▶ Воспроизведение"
                            BackgroundColor="#9C27B0"
                            TextColor="White"
                            FontSize="14" FontAttributes="Bold"
                            CornerRadius="25"
                            HeightRequest="45"
                            Clicked="OnTtsClicked"/>
                    <Button x:Name="StopButton"
                            Text="⏹ Стоп"
                            Grid.Column="2"
                            BackgroundColor="#757575"
                            TextColor="White"
                            FontSize="14" FontAttributes="Bold"
                            CornerRadius="25"
                            WidthRequest="80"
                            HeightRequest="45"
                            Clicked="OnStopClicked"
                            IsEnabled="False"/>
                </Grid>
                <Grid ColumnSpacing="10" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="GrammarButton"
                            Grid.Column="0"
                            Text="📝 Разбор"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            FontSize="14" FontAttributes="Bold"
                            CornerRadius="25"
                            HeightRequest="45"
                            Clicked="OnGrammarAnalysisClicked"/>
                    <Button x:Name="TranslateSelectedButton"
                            Grid.Column="1"
                            Text="📖 Перевод"
                            BackgroundColor="#FF5722"
                            TextColor="White"
                            FontSize="14" FontAttributes="Bold"
                            CornerRadius="25"
                            HeightRequest="45"
                            Clicked="OnTranslateSelectedClicked"/>
                </Grid>
            </StackLayout>
        </Frame>

        <!-- Bottom "Open in browser" button (unchanged) -->
        <Frame Grid.Row="4" BackgroundColor="White" CornerRadius="0" Padding="15" HasShadow="True">
            <Button x:Name="OpenUrlButton" 
                    Text="🔗 Читать полностью на сайте" 
                    BackgroundColor="#1976D2" 
                    TextColor="White" 
                    FontSize="14" FontAttributes="Bold"
                    CornerRadius="25"
                    HeightRequest="45"
                    Clicked="OnOpenUrlClicked"/>
        </Frame>
    </Grid>
</ContentPage>