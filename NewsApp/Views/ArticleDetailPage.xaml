<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApp.Views.ArticleDetailPage"
             Title="{Binding ArticleTitle}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <HorizontalStackLayout Spacing="10" Padding="10">
            <Button Text="🔊 Audio" Command="{Binding PlayAudioCommand}" BackgroundColor="LightBlue"/>
            <Button Text="📖 Grammar" Command="{Binding AnalyzeGrammarCommand}" BackgroundColor="LightGreen"/>
            <ActivityIndicator IsRunning="{Binding IsLoadingAnalysis}" IsVisible="{Binding IsLoadingAnalysis}"/>
        </HorizontalStackLayout>
        <WebView Grid.Row="1" x:Name="ArticleWebView" 
                 Navigating="OnWebViewNavigating"
                 Navigated="OnWebViewNavigated"/>
    </Grid>
</ContentPage>