<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApp.Views.ArticleDetailPage"
             Title="Статья">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackLayout Grid.Row="0" Padding="15">
            <Label x:Name="TitleLabel" FontSize="22" FontAttributes="Bold" TextColor="Black"/>
            <Label x:Name="SummaryLabel" FontSize="14" TextColor="Gray" Margin="0,10,0,0"/>
            <Label x:Name="SourceLabel" FontSize="12" TextColor="Blue" Margin="0,5,0,0"/>
        </StackLayout>
        
        <StackLayout Grid.Row="1" Orientation="Horizontal" Padding="15,0" Spacing="10">
            <Label Text="Прогресс:" FontSize="14" TextColor="Gray" VerticalOptions="Center"/>
            <CheckBox x:Name="ReadCheckBox" Color="#4CAF50"/>
            <Label x:Name="ReadLabel" Text="Прочитано" FontSize="14" TextColor="Gray" VerticalOptions="Center"/>
            <CheckBox x:Name="FavoriteCheckBox" Color="#FF9800"/>
            <Label x:Name="FavoriteLabel" Text="В избранное" FontSize="14" TextColor="Gray" VerticalOptions="Center"/>
        </StackLayout>
        
        <ScrollView Grid.Row="2" Padding="15,0">
            <Label x:Name="ContentLabel" FontSize="14" TextColor="Black"/>
        </ScrollView>
        
        <Button Grid.Row="3" x:Name="OpenUrlButton" Text="Читать полностью" Margin="15" BackgroundColor="#2196F3" TextColor="White"/>
    </Grid>
</ContentPage>